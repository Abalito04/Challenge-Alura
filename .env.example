# Provider configuration - never place real keys in this file
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.5-flash
LLM_FALLBACK_MODEL=gemini-2.5-flash
EMBEDDINGS_PROVIDER=gemini
EMBEDDINGS_MODEL=gemini-embedding-001
GEMINI_API_KEY=replace_with_your_local_key

# RAG configuration
SOURCE_DOCUMENTS_DIR=source_documents
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION=medinova_documents
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RETRIEVAL_K=3
RETRIEVAL_SCORE_THRESHOLD=0.25
