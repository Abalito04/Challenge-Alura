# Provider configuration - never place real keys in this file
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.5-flash
LLM_FALLBACK_PROVIDER=gemini
LLM_FALLBACK_MODEL=gemini-2.5-flash
EMBEDDINGS_PROVIDER=gemini
EMBEDDINGS_MODEL=gemini-embedding-001
GEMINI_API_KEY=replace_with_your_local_key
# GOOGLE_API_KEY is also accepted as an alias for GEMINI_API_KEY
OPENAI_API_KEY=replace_with_your_local_key
COHERE_API_KEY=replace_with_your_local_key

# Streamlit document upload gate
DOCUMENT_UPLOAD_PASSWORD=replace_with_a_local_upload_password

# Alternative model examples (change provider and model together)
# OpenAI chat: gpt-5.4-mini | embeddings: text-embedding-3-small
# Cohere chat: command-a-03-2025 | embeddings: embed-v4.0

# RAG configuration
SOURCE_DOCUMENTS_DIR=source_documents
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION=medinova_documents
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RETRIEVAL_K=3
RETRIEVAL_SCORE_THRESHOLD=0.25
